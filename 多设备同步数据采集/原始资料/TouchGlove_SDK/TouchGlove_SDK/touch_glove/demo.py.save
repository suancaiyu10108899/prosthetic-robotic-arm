import serial
import time
import sys

def test():
    try:
        p = serial.Serial('/dev/ttyACM0', 115200, timeout=0.1)
    except Exception as e:
        print("open error:", e)
        return
    
    print("Opened port. Sending STOP x5")
    for _ in range(5):
        p.write(bytes([0x55, 0xAA, 0x01, 0x01, 0x04, 0x00, 0x04, 0xE4, 0xDF])) # this is just a dummy, let's see if we can use the exact frame
        time.sleep(0.01)
    
    print("Draining...")
    start = time.time()
    while time.time() - start < 0.2:
        p.read(1024)
        
    print("Sending UID request")
    # TYPE_HOST_DEV=0x01, CMD=0x05 (CMD_UNIQUE_ID)
    # len=2 (no param) -> wait, header is 0x55 0xAa
    # addr = 1
    # len = 2
    # type = 1, cmd = 5
    # cksum = sum % 256
    # tail = 0xE4 0xDF
    p.write(bytes([0x55, 0xAA, 0x01, 0x02, 0x00, 0x01, 0x05, 0x08, 0xE4, 0xDF])) # computed roughly
    
    start = time.time()
    while time.time() - start < 1.0:
        res = p.read(1024)
        if res:
            print("Got data:", res.hex())
            if bytes([0x01, 0x05]) in res or bytes([0x02, 0x05]) in res:
                print("Got UID ACK.")
                return
    print("Timeout.")

test()
