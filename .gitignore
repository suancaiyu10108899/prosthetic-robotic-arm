# =============================================================
# 假肢机械臂项目 - Git 忽略规则
# =============================================================

# ----------------------------
# 大文件（>10MB）一律不入库
# ----------------------------
*.stl
*.STL
*.SLDPRT
*.SLDASM
*.SLDDRW
*.step
*.STEP
*.iges
*.IGES
*.sldprt
*.sldasm
*.slddrw

# ----------------------------
# SolidWorks 临时文件
# ----------------------------
~$*.SLDPRT
~$*.SLDASM
~$*.SLDDRW
*.swp
*.SWP
*.swnotify
# SolidWorks 备份文件
*_bak*.SLDPRT
*_bak*.SLDASM
*_bak*.SLDDRW

# ----------------------------
# 电路设计文件（可选：如需版本管理可取消注释）
# ----------------------------
*.bkp
*.drc
*.DRC
*.sav
*.SAV

# ----------------------------
# 编译产物
# ----------------------------
*.o
*.obj
*.elf
*.hex
*.bin
*.exe
*.out
*.map
/build/
/dist/

# ----------------------------
# 固件与依赖库
# ----------------------------
node_modules/
vendor/
__pycache__/
*.pyc
*.pyo
.pio/

# ----------------------------
# SDK 二进制文件（不可入 Git）
# ----------------------------
*.so
*.pyd
*.enc
*.egg
*.whl

# ----------------------------
# IDE & 编辑器文件
# ----------------------------
.vscode/settings.json
.vscode/launch.json
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ----------------------------
# 实验数据（如包含大体积原始数据）
# — 只排除原始资料目录和实验记录目录下的大文件
# — 不全局排除，避免误伤项目文档
# ----------------------------
原始资料/**/*.mat
原始资料/**/*.csv
原始资料/**/*.xlsx
原始资料/**/*.xls
原始资料/**/*.txt
原始资料/**/*.log
实验记录/**/*.mat
实验记录/**/*.csv
实验记录/**/*.xlsx
实验记录/**/*.xls
实验记录/**/*.txt
实验记录/**/*.log

# ----------------------------
# 敏感信息
# ----------------------------
.env
*.env
*.secret
secrets/

# ----------------------------
# 临时与缓存文件
# ----------------------------
*.tmp
*.temp
*.cache
*.bak

# 注意：
# - STL/SolidWorks 文件通常很大（几十MB-几百MB），默认不入 Git
# - 如需追踪小文件，可在具体目录下另行 .gitignore 覆盖规则
# - 建议大文件用 U盘/移动硬盘 手动备份，或使用 Git LFS